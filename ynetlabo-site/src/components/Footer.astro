---
import { SITE, SOCIAL, NAV } from "../consts";
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <img src="/ynetlabo-wordmark.png" alt="Y.NetLabo" class="footer-logo" width="891" height="231" />
      <p class="footer-tagline">{SITE.tagline}</p>
      <div class="footer-social">
        <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 5 18 5.3 18 5.3c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
        </a>
        <a href={SOCIAL.x} target="_blank" rel="noopener noreferrer" aria-label="X">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M18.9 1.2h3.7l-8 9.2 9.4 12.4h-7.4l-5.8-7.6-6.6 7.6H.5l8.6-9.8L0 1.2h7.6l5.2 6.9 6.1-6.9zm-1.3 19.6h2L6.5 3.3H4.4l13.2 17.5z"/></svg>
        </a>
        <a href={`mailto:${SITE.email}`} aria-label="メール">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        </a>
      </div>
    </div>

    <nav class="footer-nav" aria-label="サイトリンク">
      <h3>サイト</h3>
      <ul>
        {NAV.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <nav class="footer-nav" aria-label="その他">
      <h3>その他</h3>
      <ul>
        <li><a href="/contact">お問い合わせ</a></li>
        <li><a href="/privacy">プライバシーポリシー</a></li>
      </ul>
    </nav>
  </div>

  <div class="footer-bottom">
    <div class="wrap">
      <p>© {SITE.copyrightYear} Y.NetLabo</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    background: var(--color-ink);
    color: #c7d0e0;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2.5rem;
    padding-block: 3.5rem 2.5rem;
  }
  .footer-logo {
    height: 2rem;
    width: auto;
    display: block;
    /* monochrome logo -> white for the dark footer */
    filter: brightness(0) invert(1);
  }
  .footer-tagline {
    margin-top: 0.85rem;
    font-size: 0.9rem;
    max-width: 22rem;
    color: #9aa6bd;
  }
  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }
  .footer-social a {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .footer-social a:hover {
    background: var(--color-accent);
    transform: translateY(-2px);
  }
  .footer-nav h3 {
    color: #fff;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }
  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .footer-nav a {
    color: #9aa6bd;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.15s ease;
  }
  .footer-nav a:hover {
    color: #fff;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-block: 1.25rem;
  }
  .footer-bottom p {
    font-size: 0.82rem;
    color: #8390a8;
  }
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
</style>
