---
import { NAV, SITE } from "../consts";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="brand" aria-label={SITE.name}>
      <img src="/ynetlabo-wordmark.png" alt="Y.NetLabo" class="brand-logo" width="891" height="231" />
    </a>

    <nav class="nav" aria-label="グローバルナビゲーション">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={["nav-link", { active: isActive(item.href) }]}
          >
            {item.label}
          </a>
        ))
      }
      <a href="/contact" class="btn btn-accent nav-cta">お問い合わせ</a>
    </nav>

    <div class="header-actions">
      <button class="theme-toggle" aria-label="テーマを切り替える" type="button">
        <svg class="icon-sun" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
        </svg>
        <svg class="icon-moon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
        </svg>
      </button>

      <button class="nav-toggle" aria-label="メニューを開く" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 80%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    box-shadow: 0 4px 16px -10px var(--nm-dark);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.25rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .brand-logo {
    height: 1.85rem;
    width: auto;
    display: block;
  }
  /* monochrome navy wordmark -> light in dark theme */
  :global([data-theme="dark"]) .brand-logo {
    filter: brightness(0) invert(1);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .theme-toggle {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border: none;
    border-radius: 999px;
    background: var(--color-bg);
    color: var(--color-ink);
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s ease, color 0.2s ease;
  }
  .theme-toggle:hover {
    color: var(--color-accent-ink);
  }
  .theme-toggle:active {
    box-shadow: var(--shadow-pressed-sm);
  }
  .theme-toggle .icon-moon {
    display: none;
  }
  :global([data-theme="dark"]) .theme-toggle .icon-sun {
    display: none;
  }
  :global([data-theme="dark"]) .theme-toggle .icon-moon {
    display: block;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }
  .nav-link {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-body);
    text-decoration: none;
    position: relative;
    padding-block: 0.25rem;
    transition: color 0.15s ease;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width 0.2s ease;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-ink);
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }
  .nav-cta {
    padding: 0.55rem 1.2rem;
    font-size: 0.9rem;
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--color-ink);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 768px) {
    .nav {
      position: fixed;
      inset: 4.25rem 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--color-bg);
      padding: 0.5rem 1.25rem 1.25rem;
      box-shadow: 0 14px 28px -16px var(--nm-dark);
      transform: translateY(-120%);
      transition: transform 0.25s ease;
    }
    .nav.open {
      transform: translateY(0);
    }
    .nav-link {
      padding: 0.9rem 0.25rem;
      border-bottom: 1px solid var(--color-line);
    }
    .nav-cta {
      margin-top: 1rem;
      text-align: center;
    }
    .nav-toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const nav = document.querySelector(".nav");
  toggle?.addEventListener("click", () => {
    const open = nav?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!!open));
  });

  const themeToggle = document.querySelector(".theme-toggle");
  themeToggle?.addEventListener("click", () => {
    const root = document.documentElement;
    const next = root.dataset.theme === "dark" ? "light" : "dark";
    root.dataset.theme = next;
    try {
      localStorage.setItem("theme", next);
    } catch (_) {}
  });
</script>
