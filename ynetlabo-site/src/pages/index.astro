---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { PROJECTS, PROFILE, SITE, SOCIAL } from "../consts";
import { articleHref } from "../utils";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latest = posts.slice(0, 3);
---

<BaseLayout>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-copy">
        <span class="eyebrow">App Development Lab</span>
        <h1 class="hero-title">
          シンプルなアプリに、<br />少しのペンギンを。
        </h1>
        <p class="hero-lead">{SITE.taglineEn}</p>
        <p class="hero-desc">{SITE.description}</p>
        <div class="hero-actions">
          <a href="#projects" class="btn btn-accent">プロダクトを見る</a>
          <a href="/article" class="btn btn-ghost">記事を読む</a>
        </div>
      </div>
      <div class="hero-art" aria-hidden="true">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <img class="penguin" src="/penguin-mark.png" alt="" width="235" height="235" />
      </div>
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="section">
    <div class="wrap about-grid">
      <div>
        <span class="eyebrow">About</span>
        <h2 class="section-title">必要な機能だけを、丁寧に。</h2>
      </div>
      <div class="about-body">
        <p>
          Y.NetLabo は、企業ではなく「アプリ開発が好きな個人」のラボです。多機能で複雑なものより、<strong
            >迷わず使えるシンプルなアプリ</strong
          >を目指しています。
        </p>
        <p>
          不要な機能はそぎ落とし、本当に必要な機能だけを残す。そこに、ちょっとした遊び心としてペンギンのモチーフを添えています。使う人が「これで十分」と思える道具を作ることが、このラボのテーマです。
        </p>
      </div>
    </div>
  </section>

  <!-- ============ PROJECTS ============ -->
  <section id="projects" class="section section-mist">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Products</span>
        <h2 class="section-title">つくったアプリ</h2>
        <p class="section-sub">個人開発で世に出してきたプロダクトたち。</p>
      </div>

      <div class="project-grid">
        {
          PROJECTS.map((p) => (
            <article class="card project-card">
              <div class="project-top" style={`--brand:${p.accent}`}>
                <span class="project-dot" />
                <h3 class="project-name">{p.name}</h3>
                <span class="project-tag">{p.tagline}</span>
              </div>
              <p class="project-desc">{p.description}</p>
              <div class="project-links">
                {p.site && (
                  <a class="plink plink-primary" href={p.site} target="_blank" rel="noopener noreferrer">
                    公式サイト
                  </a>
                )}
                {p.appStore && (
                  <a class="plink" href={p.appStore} target="_blank" rel="noopener noreferrer">
                    App Store
                  </a>
                )}
                {p.googlePlay && (
                  <a class="plink" href={p.googlePlay} target="_blank" rel="noopener noreferrer">
                    Google Play
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ LATEST ARTICLES ============ -->
  <section class="section">
    <div class="wrap">
      <div class="section-head row">
        <div>
          <span class="eyebrow">Blog</span>
          <h2 class="section-title">最新の記事</h2>
        </div>
        <a href="/article" class="link-arrow">すべての記事 →</a>
      </div>

      <div class="article-grid">
        {
          latest.map((post) => (
            <ArticleCard
              href={articleHref(post.data.wpId)}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              categories={post.data.categories}
              heroImage={post.data.heroImage}
              heroAlt={post.data.heroAlt}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ PROFILE ============ -->
  <section class="section section-mist">
    <div class="wrap profile-grid">
      <div class="profile-card card">
        <div class="profile-avatar">
          <img src="/penguin-mark.png" alt="yuuki" width="235" height="235" />
        </div>
        <div>
          <h3 class="profile-name">{PROFILE.name}</h3>
          <p class="profile-role">{PROFILE.role}</p>
        </div>
      </div>
      <div class="profile-body">
        <span class="eyebrow">Profile</span>
        <h2 class="section-title">つくっている人</h2>
        <p>{PROFILE.bio}</p>
        <div class="stack">
          {PROFILE.stack.map((s) => <span class="chip">{s}</span>)}
        </div>
        <div class="profile-social">
          <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">GitHub</a>
          <a href={SOCIAL.x} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">X (Twitter)</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CONTACT CTA ============ -->
  <section class="section">
    <div class="wrap">
      <div class="cta">
        <h2 class="cta-title">お気軽にご連絡ください</h2>
        <p class="cta-sub">
          アプリへのご感想・ご要望、不具合のご報告などお待ちしています。
        </p>
        <div class="cta-actions">
          <a href="/contact" class="btn btn-accent">お問い合わせ</a>
          <a href={`mailto:${SITE.email}`} class="btn btn-ghost">{SITE.email}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ----- section primitives ----- */
  .section {
    padding-block: 4.5rem;
  }
  .section-mist {
    background: var(--color-mist);
  }
  .section-head {
    margin-bottom: 2.5rem;
  }
  .section-head.row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }
  .section-title {
    font-size: clamp(1.5rem, 1.2rem + 1.4vw, 2rem);
    margin-top: 0.6rem;
  }
  .section-sub {
    margin-top: 0.6rem;
    color: var(--color-muted);
  }
  .link-arrow {
    font-weight: 700;
    color: var(--color-accent-ink);
    text-decoration: none;
    white-space: nowrap;
  }

  /* ----- hero ----- */
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #fff 0%, var(--color-mist) 100%);
    border-bottom: 1px solid var(--color-line);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 2rem;
    padding-block: clamp(3.5rem, 2rem + 6vw, 6.5rem);
  }
  .hero-title {
    font-size: clamp(2rem, 1.4rem + 3.2vw, 3.4rem);
    line-height: 1.3;
    margin-top: 1rem;
  }
  .hero-lead {
    font-family: var(--font-display);
    color: var(--color-accent-ink);
    font-weight: 700;
    margin-top: 1rem;
    letter-spacing: 0.02em;
  }
  .hero-desc {
    margin-top: 1.25rem;
    max-width: 32rem;
    color: var(--color-muted);
  }
  .hero-actions {
    display: flex;
    gap: 0.9rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .hero-art {
    position: relative;
    height: 22rem;
  }
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(8px);
  }
  .blob-1 {
    width: 18rem;
    height: 18rem;
    right: 1rem;
    top: 1rem;
    background: radial-gradient(circle at 30% 30%, #fed7aa, #f97316);
    opacity: 0.85;
  }
  .blob-2 {
    width: 11rem;
    height: 11rem;
    left: 1rem;
    bottom: 0.5rem;
    background: radial-gradient(circle at 30% 30%, #bae6fd, #0ea5e9);
    opacity: 0.55;
  }
  .penguin {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 9rem;
    height: auto;
    filter: drop-shadow(0 16px 30px rgba(20, 33, 61, 0.25));
    animation: float 5s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }

  /* ----- about ----- */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 2.5rem;
  }
  .about-body p + p {
    margin-top: 1.1rem;
  }
  .about-body strong {
    color: var(--color-ink);
  }

  /* ----- projects ----- */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .project-card {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
  }
  .project-top {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .project-dot {
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 50%;
    background: var(--brand);
  }
  .project-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
  }
  .project-tag {
    width: 100%;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-muted);
  }
  .project-desc {
    font-size: 0.92rem;
    color: var(--color-body);
    flex: 1;
  }
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }
  .plink {
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.45rem 0.9rem;
    border-radius: 999px;
    border: 1.5px solid var(--color-line);
    color: var(--color-ink);
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .plink:hover {
    border-color: var(--color-ink);
  }
  .plink-primary {
    background: var(--color-ink);
    color: #fff;
    border-color: var(--color-ink);
  }
  .plink-primary:hover {
    background: var(--color-ink-soft);
  }

  /* ----- articles ----- */
  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ----- profile ----- */
  .profile-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 2.5rem;
    align-items: center;
  }
  .profile-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.75rem;
  }
  .profile-avatar {
    display: grid;
    place-items: center;
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #fff, #e2e8f0);
    border: 1px solid var(--color-line);
    flex-shrink: 0;
    overflow: hidden;
  }
  .profile-avatar img {
    width: 58%;
    height: auto;
  }
  .profile-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
  }
  .profile-role {
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .profile-body p {
    margin-top: 1rem;
    color: var(--color-body);
  }
  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .profile-social {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.75rem;
    flex-wrap: wrap;
  }

  /* ----- CTA ----- */
  .cta {
    background: var(--color-ink);
    color: #fff;
    border-radius: 24px;
    padding: clamp(2.5rem, 1.5rem + 4vw, 4rem);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta::after {
    content: "";
    position: absolute;
    right: 1.5rem;
    bottom: -1rem;
    width: 8rem;
    height: 8rem;
    background: url("/penguin-mark.png") center / contain no-repeat;
    filter: brightness(0) invert(1);
    opacity: 0.1;
  }
  .cta-title {
    color: #fff;
    font-size: clamp(1.5rem, 1.2rem + 1.4vw, 2.1rem);
  }
  .cta-sub {
    color: #b8c2d6;
    margin-top: 0.85rem;
  }
  .cta-actions {
    display: flex;
    gap: 0.9rem;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .cta .btn-ghost {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.3);
  }
  .cta .btn-ghost:hover {
    border-color: #fff;
  }

  /* ----- responsive ----- */
  @media (max-width: 900px) {
    .project-grid,
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .hero-inner,
    .about-grid,
    .profile-grid {
      grid-template-columns: 1fr;
    }
    .hero-art {
      height: 14rem;
      order: -1;
    }
    .penguin {
      width: 6rem;
    }
    .project-grid,
    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
