---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { articleHref } from "../utils";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// build category list with counts
const counts = new Map<string, number>();
for (const p of posts)
  for (const c of p.data.categories) counts.set(c, (counts.get(c) ?? 0) + 1);
const categories = [...counts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout
  title="記事"
  description="アプリ開発の知見や、つくったプロダクトの裏側を記録しています。"
>
  <section class="page-head">
    <div class="wrap">
      <span class="eyebrow">Blog</span>
      <h1 class="page-title">記事</h1>
      <p class="page-sub">
        アプリ開発で得た知見や、プロダクトの裏側を記録しています。
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="cat-filter">
        <button type="button" class="cat-pill active" data-cat="">
          すべて ({posts.length})
        </button>
        {
          categories.map(([name, count]) => (
            <button type="button" class="cat-pill" data-cat={name}>
              {name} ({count})
            </button>
          ))
        }
      </div>

      <div class="article-grid">
        {
          posts.map((post) => (
            <div class="article-item" data-categories={post.data.categories.join("|")}>
              <ArticleCard
                href={articleHref(post.data.wpId)}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                categories={post.data.categories}
                heroImage={post.data.heroImage}
                heroAlt={post.data.heroAlt}
              />
            </div>
          ))
        }
      </div>
      <p class="no-results" hidden>このカテゴリの記事はありません。</p>
    </div>
  </section>

  <script>
    const pills = document.querySelectorAll<HTMLButtonElement>(".cat-pill");
    const items = document.querySelectorAll<HTMLElement>(".article-item");
    const empty = document.querySelector<HTMLElement>(".no-results");

    pills.forEach((pill) => {
      pill.addEventListener("click", () => {
        const cat = pill.dataset.cat ?? "";
        pills.forEach((p) => p.classList.toggle("active", p === pill));

        let visible = 0;
        items.forEach((item) => {
          const cats = (item.dataset.categories ?? "").split("|");
          const show = cat === "" || cats.includes(cat);
          item.hidden = !show;
          if (show) visible++;
        });

        if (empty) empty.hidden = visible !== 0;
      });
    });
  </script>
</BaseLayout>

<style>
  .page-head {
    padding-block: 3rem 1rem;
    background: var(--color-mist);
    box-shadow: inset 0 -8px 16px -12px var(--nm-dark);
  }
  .page-title {
    font-size: clamp(1.8rem, 1.4rem + 2vw, 2.6rem);
    margin-top: 0.6rem;
  }
  .page-sub {
    margin-top: 0.75rem;
    color: var(--color-muted);
  }
  .section {
    padding-block: 3rem 4.5rem;
  }
  .cat-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2.5rem;
  }
  .cat-pill {
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.5rem 1.05rem;
    border: none;
    border-radius: 999px;
    color: var(--color-body);
    background: var(--color-bg);
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    transition: box-shadow 0.2s ease, color 0.15s ease;
  }
  .cat-pill:hover {
    color: var(--color-accent-ink);
  }
  .cat-pill.active {
    background: var(--color-panel);
    color: var(--color-on-panel);
    box-shadow: var(--shadow-pressed-sm);
  }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 900px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
