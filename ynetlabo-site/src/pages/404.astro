---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="ページが見つかりません" noindex={true}>
  <section class="nf">
    <div class="wrap-narrow nf-inner">
      <img class="nf-penguin" src="/penguin-mark.png" alt="" width="235" height="235" />
      <p class="nf-code">404</p>
      <h1 class="nf-title">ページが見つかりませんでした</h1>
      <p class="nf-text">
        お探しのページは移動または削除された可能性があります。
      </p>
      <div class="nf-actions">
        <a href="/" class="btn btn-accent">ホームへ戻る</a>
        <a href="/article" class="btn btn-ghost">記事一覧</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    padding-block: 6rem;
    text-align: center;
  }
  .nf-penguin {
    width: 4.5rem;
    height: auto;
    margin: 0 auto;
    display: block;
  }
  .nf-code {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 3rem;
    color: var(--color-accent);
  }
  .nf-title {
    font-size: clamp(1.4rem, 1.1rem + 1.4vw, 1.9rem);
    margin-top: 0.5rem;
  }
  .nf-text {
    color: var(--color-muted);
    margin-top: 0.85rem;
  }
  .nf-actions {
    display: flex;
    gap: 0.9rem;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
</style>
